  .fcr-charts {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-block: 2rem;
  }

  .fcr-chart-section {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1.5rem;
    background: var(--sl-color-gray-7);
  }

  .fcr-chart-title {
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .fcr-chart-subtitle {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    line-height: 1.4;
  }

  .fcr-chart-container {
    position: relative;
    height: 300px;
    width: 100%;
  }

  .fcr-chart-container.fcr-chart-pie {
    height: 280px;
  }

  @media (max-width: 600px) {
    .fcr-chart-container {
      height: 250px;
    }
    .fcr-chart-section {
      padding: 1rem;
    }
  }
</style>
